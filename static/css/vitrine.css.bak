/* ================================================================
   VITRINE — MedMarket Commercial Showcase
   Clean Modern Dark + Clinical Tech Dark search bar
   ================================================================ */

/* Override dark body background for vitrine page */
body {
  background: #111827;
}

/* Overlay behind open panels */
.airbnb-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.52);
  z-index: 190;
  backdrop-filter: blur(1.5px);
}
.airbnb-overlay.show { display: block; }

/* Panels wrapper — provides relative positioning anchor */
.ab-panels-wrap { position: relative; }

/* ── PILL BAR ── */
.ab-bar {
  display: flex;
  align-items: center;
  background: #1b2436;
  border: 1.5px solid rgba(255,255,255,.12);
  border-radius: 999px;
  box-shadow: 0 10px 44px rgba(0,0,0,.5), 0 2px 8px rgba(0,0,0,.3);
  min-height: 4.4rem;
  position: relative;
  z-index: 201;
  transition: box-shadow .22s;
}
.ab-bar.ab-bar--active {
  box-shadow: 0 10px 56px rgba(0,0,0,.65), 0 2px 8px rgba(0,0,0,.3);
}

/* ── SEGMENTS ── */
.ab-seg {
  flex: 1;
  display: flex;
  align-items: center;
  padding: .7rem 1rem;
  border-radius: 999px;
  cursor: pointer;
  transition: background .18s;
  min-width: 0;
  user-select: none;
}
.ab-seg:hover:not(.ab-seg--active) { background: rgba(255,255,255,.07); }
.ab-seg--active { background: rgba(255,255,255,.11); }

.ab-seg--price {
  gap: .6rem;
  padding-right: .45rem;
  flex: 1.1;
}

.ab-seg-inner {
  display: flex;
  flex-direction: column;
  gap: .15rem;
  min-width: 0;
  flex: 1;
}

.ab-seg-label {
  font-size: .6rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .09em;
  color: #8aaac8;
  display: flex;
  align-items: center;
  gap: .28rem;
  white-space: nowrap;
}
.ab-seg-val {
  font-size: .88rem;
  font-weight: 600;
  color: #dff0ff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ab-seg-val--placeholder { color: #4d6a82; font-weight: 500; }
.ab-seg-val--muted       { color: #4d6a82; font-weight: 500; }

.ab-opt {
  display: inline-block;
  font-size: .53rem;
  font-weight: 600;
  padding: .06rem .28rem;
  border-radius: 999px;
  background: rgba(148,163,184,.1);
  border: 1px solid rgba(148,163,184,.18);
  color: #55728a;
  letter-spacing: .03em;
  text-transform: none;
  vertical-align: .06em;
}

/* Dividers */
.ab-divider {
  width: 1px;
  height: 2.2rem;
  background: rgba(255,255,255,.15);
  flex-shrink: 0;
  transition: opacity .18s;
}
.ab-bar.ab-bar--active .ab-divider { opacity: .35; }

/* ── SEARCH BUTTON ── */
.ab-submit {
  display: inline-flex;
  align-items: center;
  gap: .38rem;
  padding: .62rem 1.05rem .62rem .72rem;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  background: linear-gradient(135deg, #00c6ff 0%, #00ef9c 100%);
  color: #00131c;
  font-family: inherit;
  font-size: .82rem;
  font-weight: 800;
  letter-spacing: .01em;
  box-shadow: 0 8px 26px rgba(0,198,255,.3);
  flex-shrink: 0;
  transition: filter .18s, transform .18s;
}
.ab-submit:hover { filter: brightness(1.08); transform: scale(1.03); }
.ab-submit svg  { width: .92rem; height: .92rem; }

/* ── DROPDOWN PANELS ── */
.ab-panel {
  display: none;
  position: absolute;
  top: calc(100% + .55rem);
  background: rgba(18, 26, 44, 0.93);
  backdrop-filter: blur(20px) saturate(1.6);
  -webkit-backdrop-filter: blur(20px) saturate(1.6);
  border: 1.5px solid rgba(255,255,255,.14);
  border-radius: 1.3rem;
  padding: 1.1rem 1.25rem 1.3rem;
  box-shadow: 0 24px 64px rgba(0,0,0,.6), 0 4px 16px rgba(0,0,0,.3);
  z-index: 210;
  min-width: 300px;
  animation: abPanelIn .16s ease;
}
.ab-panel--show { display: block; }

@keyframes abPanelIn {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Panel positions */
#panelOnde { left: 0; min-width: 340px; }
#panelCal  { left: 15%; min-width: 690px; }
#panelSpec { left: 47%; width: 500px; }
#panelPreco { right: .2rem; }

.ab-panel--wide { min-width: 500px; }
.ab-panel--right { right: .2rem; left: auto; }

.ab-panel-label {
  display: flex;
  align-items: center;
  gap: .35rem;
  font-size: .65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .09em;
  color: #7aa4c8;
  margin-bottom: .62rem;
}

.ab-panel-hint {
  font-size: .78rem;
  color: var(--muted);
  line-height: 1.55;
  margin-bottom: .8rem;
}

.ab-panel-input {
  width: 100%;
  background: rgba(255,255,255,.06);
  border: 1.5px solid rgba(255,255,255,.14);
  border-radius: .8rem;
  padding: .65rem .9rem;
  font-family: inherit;
  font-size: .92rem;
  font-weight: 600;
  color: #e2f0ff;
  outline: none;
  transition: border-color .18s, background .18s;
}
.ab-panel-input:focus {
  border-color: #00c6ff;
  background: rgba(0,198,255,.05);
}
.ab-panel-input::placeholder { color: #405468; font-weight: 400; }
.ab-panel-input::-webkit-calendar-picker-indicator { filter: invert(.55); cursor: pointer; }

/* Specialty grid */
.ab-spec-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: .45rem;
}

.ab-spec-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .32rem;
  padding: .6rem .3rem;
  border: 1.5px solid rgba(255,255,255,.1);
  border-radius: .8rem;
  background: transparent;
  cursor: pointer;
  color: var(--muted);
  font-family: inherit;
  font-size: .65rem;
  font-weight: 600;
  text-align: center;
  transition: border-color .15s, color .15s, background .15s;
}
.ab-spec-btn svg { width: 1.15rem; height: 1.15rem; }
.ab-spec-btn:hover {
  border-color: rgba(0,198,255,.42);
  color: #c8eeff;
  background: rgba(0,198,255,.07);
}
.ab-spec-btn--active {
  border-color: #00c6ff;
  background: rgba(0,198,255,.12);
  color: #00d9ff;
}

/* Price input */
.ab-price-wrap {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,.06);
  border: 1.5px solid rgba(255,255,255,.14);
  border-radius: .8rem;
  overflow: hidden;
  transition: border-color .18s;
}
.ab-price-wrap:focus-within { border-color: #00c6ff; }

.ab-price-prefix {
  padding: .65rem .8rem;
  font-size: .9rem;
  font-weight: 700;
  color: #4d6a82;
  border-right: 1px solid rgba(255,255,255,.1);
  flex-shrink: 0;
}

.ab-panel-input--price {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: .65rem .8rem;
}
.ab-panel-input--price:focus { background: transparent; border-color: transparent; }

/* ── RESPONSIVE ── */
@media (max-width: 800px) {
  .ab-bar {
    border-radius: 1.2rem;
    flex-direction: column;
    align-items: stretch;
    min-height: auto;
    padding: .35rem;
  }
  .ab-seg { border-radius: .85rem; }
  .ab-seg--price { flex-direction: row; align-items: center; }
  .ab-divider { display: none; }
  .ab-submit { flex: 1; justify-content: center; }
  .ab-panel {
    position: fixed !important;
    left: .75rem !important; right: .75rem !important;
    top: auto !important; bottom: 0 !important;
    border-radius: 1.3rem 1.3rem 0 0;
    min-width: 0 !important; width: auto !important;
  }
  .ab-panel--wide { min-width: 0 !important; }
  .ab-spec-grid { grid-template-columns: repeat(3, 1fr); }
  #panelCal { min-width: 0 !important; }
  .ab-cal-months { grid-template-columns: 1fr; }
  .ab-cal-nav-row { flex-direction: column; gap: .5rem; }
  .ab-cal-nav { margin-top: 0; align-self: flex-start; }
}

/* ── CITY CHIPS (Onde panel) ────────────────────────────────────── */
.ab-city-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: .33rem;
  margin-bottom: .7rem;
}
.ab-city-btn {
  display: flex;
  align-items: center;
  gap: .45rem;
  padding: .5rem .7rem;
  border: 1.5px solid rgba(255,255,255,.09);
  border-radius: .75rem;
  background: transparent;
  cursor: pointer;
  color: #9dbcd6;
  font-family: inherit;
  font-size: .78rem;
  font-weight: 600;
  text-align: left;
  transition: border-color .15s, background .15s, color .15s;
}
.ab-city-btn:hover {
  border-color: rgba(0,198,255,.35);
  background: rgba(0,198,255,.06);
  color: #c8eeff;
}
.ab-city-btn--active {
  border-color: #00c6ff;
  background: rgba(0,198,255,.1);
  color: #00d9ff;
}
.ab-city-btn svg { flex-shrink: 0; color: #3d7a9a; }
.ab-city-divider {
  font-size: .6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: #3d5468;
  margin-bottom: .3rem;
  padding: .2rem 0;
}

/* ── RANGE CALENDAR ───────────────────────────────────────────────── */
.ab-panel--cal {
  padding: 1rem 1.2rem 1.3rem;
}
.ab-cal-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: .9rem;
}
.ab-cal-fields {
  display: flex;
  align-items: center;
  gap: .6rem;
  background: rgba(255,255,255,.06);
  border: 1.5px solid rgba(255,255,255,.14);
  border-radius: .8rem;
  padding: .4rem .7rem;
  flex: 1;
  cursor: default;
}
.ab-cal-field-item {
  display: flex;
  flex-direction: column;
  gap: .07rem;
  cursor: pointer;
  flex: 1;
  padding: .22rem .35rem;
  border-radius: .5rem;
  transition: background .15s;
}
.ab-cal-field-item:hover { background: rgba(255,255,255,.07); }
.ab-cal-field-item--active {
  background: rgba(255,255,255,.11);
  outline: 1.5px solid rgba(0,198,255,.4);
}
.ab-cal-field-label {
  font-size: .58rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .09em;
  color: #7aa4c8;
}
.ab-cal-field-val {
  font-size: .82rem;
  font-weight: 600;
  color: #d6eeff;
}
.ab-cal-field-val--placeholder { color: #3d5468; }
.ab-cal-clear-btn {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: .7rem;
  font-weight: 600;
  color: #4d6a82;
  font-family: inherit;
  text-decoration: underline;
  padding: .3rem .2rem;
  white-space: nowrap;
  transition: color .15s;
}
.ab-cal-clear-btn:hover { color: #8aaac8; }

/* Nav row and month grid */
.ab-cal-nav-row {
  display: flex;
  align-items: flex-start;
  gap: .6rem;
}
.ab-cal-months {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.6rem;
  flex: 1;
}
.ab-cal-nav {
  background: transparent;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: .6rem;
  padding: .28rem .6rem;
  cursor: pointer;
  color: #8aaac8;
  font-size: 1.15rem;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 1.65rem;
  transition: background .15s, color .15s;
  font-family: inherit;
}
.ab-cal-nav:hover { background: rgba(255,255,255,.1); color: #fff; }

/* Month block */
.ab-cal-month-header {
  font-size: .78rem;
  font-weight: 700;
  color: #d6eeff;
  text-align: center;
  margin-bottom: .45rem;
  letter-spacing: .015em;
}
.ab-cal-dow-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: .18rem;
}
.ab-cal-dow {
  text-align: center;
  font-size: .58rem;
  font-weight: 700;
  color: #3d5468;
  text-transform: uppercase;
  padding: .15rem 0;
}
.ab-cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

/* Calendar cells */
.ab-cal-cell {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 2.45rem;
}
/* Range corridor via pseudo-element */
.ab-cal-cell--range::before,
.ab-cal-cell--start::before,
.ab-cal-cell--end::before {
  content: '';
  position: absolute;
  top: 0; bottom: 0; left: 0; right: 0;
  background: rgba(180, 210, 240, .11);
  pointer-events: none;
}
/* Start: right-half corridor only (circle is centered, corridor extends right) */
.ab-cal-cell--start::before { left: 50%; }
/* End: left-half corridor only */
.ab-cal-cell--end::before   { right: 50%; }
/* Single (same day start+end): no corridor */
.ab-cal-cell--single::before { display: none; }

/* Day button */
.ab-cal-day {
  position: relative;
  z-index: 1;
  width: 2.15rem;
  height: 2.15rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  font-size: .78rem;
  font-weight: 500;
  color: #b8d2ea;
  font-family: inherit;
  transition: background .12s, color .12s;
}
.ab-cal-day:hover:not([disabled]) { background: rgba(255,255,255,.15); color: #fff; }
.ab-cal-day--today {
  font-weight: 800;
  text-decoration: underline;
  text-underline-offset: 3px;
  color: #d6eeff;
}
.ab-cal-day--disabled { color: #253040; cursor: not-allowed; }
/* Start / end anchors: solid white circle */
.ab-cal-cell--start .ab-cal-day,
.ab-cal-cell--end   .ab-cal-day,
.ab-cal-cell--single .ab-cal-day {
  background: #ffffff !important;
  color: #0a1420 !important;
  font-weight: 700;
}

/* ── TWO-COLUMN RESULTS SHELL ───────────────────────────────────── */
/* (replaced by .search-layout — kept for backward compatibility) */

.ct-map-head {
  display: flex;
  align-items: center;
  gap: .4rem;
  padding: .6rem .85rem;
  border-bottom: 1px solid rgba(255,255,255,.1);
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: #7aacda;
  flex-shrink: 0;
}

.ct-map-head span { flex: 1; }

.ct-map-close {
  display: flex;
  align-items: center;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--muted);
  padding: .1rem;
  transition: color .15s;
}
.ct-map-close:hover { color: #fff; }

/* Map canvas fills remaining height */
.ct-map-canvas {
  flex: 1;
  width: 100%;
  min-height: 0;
}

/* ── FLOATING MAP TOGGLE BUTTON (hidden on desktop) ─────────────── */
.map-toggle-btn {
  display: none;
}

/* ── MOBILE LAYOUT ──────────────────────────────────────────────── */
@media (max-width: 900px) {
  .search-layout {
    flex-direction: column;
    padding: 16px;
  }
  .results-column {
    width: 100%;
  }

  /* Map becomes a fullscreen overlay on mobile */
  .map-column {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 299;
    border-radius: 0;
    width: 100%;
    height: 100dvh;
    top: 0;
  }
  .map-column.ct-map-panel--visible {
    display: flex;
  }

  /* Floating toggle button */
  .map-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    position: fixed;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 280;
    padding: .65rem 1.4rem;
    border: none;
    border-radius: 999px;
    background: linear-gradient(135deg, #00c6ff, #00ef9c);
    color: #001a20;
    font-family: inherit;
    font-size: .82rem;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 8px 28px rgba(0,198,255,.38);
    white-space: nowrap;
    transition: filter .18s, transform .18s;
  }
  .map-toggle-btn:hover { filter: brightness(1.07); }
  .map-toggle-btn svg  { width: .9rem; height: .9rem; }

  /* Cards already vertical — just ensure grid works */
  .vm-grid {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    max-width: 100%;
  }
}

/* Below 500px: single column */
@media (max-width: 500px) {
  .vm-grid {
    grid-template-columns: 1fr;
  }
}

/* Leaflet pin markers */
.ct-pin-wrap { background: transparent; border: none; }

.ct-map-pin {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 70px;
  height: 28px;
  padding: 0 .5rem;
  border-radius: 999px;
  text-decoration: none;
  font-size: .72rem;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #00b8e6, #00d17a);
  border: 1.5px solid rgba(255,255,255,.35);
  box-shadow: 0 6px 18px rgba(0,217,255,.38);
  white-space: nowrap;
}

.ct-map-pin:hover { filter: brightness(1.12); }

/* Leaflet popup dark styling */
.ct-map-popup .leaflet-popup-content-wrapper {
  background: rgba(15, 22, 36, 0.97);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,.15);
  border-radius: .75rem;
  color: #c8e4f8;
  box-shadow: 0 12px 40px rgba(0,0,0,.6);
}
.ct-map-popup .leaflet-popup-tip {
  background: rgba(15, 22, 36, 0.97);
}
.ct-map-popup .leaflet-popup-close-button {
  color: #4d6a82 !important;
  top: .45rem !important;
  right: .5rem !important;
}

/* ── CARD OVERRIDES (price badge + match pill) ──────────────────── */
.vm-badge-price {
  position: absolute;
  top: .5rem; right: .5rem;
  background: rgba(0,0,0,.72);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,.18);
  color: #e8f8ff;
  font-size: .6rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: .04em;
  padding: .18rem .48rem;
  border-radius: .3rem;
}

.vm-match-pill {
  display: inline-flex;
  align-items: center;
  gap: .22rem;
  font-size: .62rem;
  font-weight: 700;
  color: #7fffd4;
  border: 1px solid rgba(0,209,122,.32);
  background: rgba(0,209,122,.08);
  border-radius: 999px;
  padding: .15rem .45rem;
}
.vm-match-pill svg { width: .65rem; height: .65rem; }

.vm-rating {
  display: inline-flex;
  align-items: center;
  gap: .2rem;
  font-size: .72rem;
  font-weight: 700;
  color: #b45309;
  white-space: nowrap;
}

/* ── OUTER LAYOUT ──────────────────────────────────────────────── */

/* ── SEARCH-LAYOUT: 60/40 flex split ───────────────────────────── */
.search-layout {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 24px;
  padding: 24px;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

/* ── RESULTS COLUMN (LEFT, 60%) ────────────────────────────────── */
.results-column {
  width: 60%;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* ── HERO CAROUSEL ─────────────────────────────────────────────── */
.hero-carousel-section {
  padding: .8rem 0 0;
}

.hero-swiper {
  width: 100%;
  height: 320px;
  border-radius: 16px;
  overflow: hidden;
  background: var(--bg2);
}

/* Slide shell */
.hi-slide {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
  text-decoration: none;
  color: var(--fg);
  overflow: hidden;
}

/* Background image */
.hi-bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .7s ease;
  will-change: transform;
}
.hi-slide:hover .hi-bg { transform: scale(1.04); }

/* Gradient overlay: strong left, fade right */
.hi-gradient {
  position: absolute; inset: 0;
  background: linear-gradient(
    to right,
    rgba(10, 14, 24, 0.88) 0%,
    rgba(10, 14, 24, 0.55) 55%,
    rgba(10, 14, 24, 0.10) 100%
  );
}

/* Content area */
.hi-content {
  position: absolute;
  bottom: 0; left: 0;
  padding: 1.75rem 2rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: .6rem;
  max-width: 520px;
}
@media (max-width: 640px) {
  .hi-content { padding: 1rem 1.1rem; gap: .4rem; max-width: 85%; }
}

.hi-tag {
  display: inline-flex;
  align-items: center;
  gap: .32rem;
  background: rgba(59, 130, 246, 0.18);
  border: 1px solid rgba(59, 130, 246, 0.4);
  color: #93c5fd;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  padding: .22rem .6rem;
  border-radius: .35rem;
  width: fit-content;
}

.hi-title {
  font-size: clamp(1.05rem, 2.4vw, 1.6rem);
  font-weight: 800;
  line-height: 1.25;
  text-shadow: 0 2px 8px rgba(0,0,0,.5);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.hi-doctor {
  display: flex;
  align-items: center;
  gap: .35rem;
  font-size: .78rem;
  color: #94a3b8;
}
@media (max-width: 480px) { .hi-doctor { display: none; } }

.hi-price {
  font-size: clamp(.95rem, 2vw, 1.3rem);
  font-weight: 800;
  color: #4ade80;
  letter-spacing: -.02em;
}

.hi-btn {
  display: inline-flex;
  align-items: center;
  gap: .42rem;
  background: var(--gradient-cta);
  color: #fff;
  font-size: .82rem;
  font-weight: 700;
  padding: .55rem 1.2rem;
  border-radius: .55rem;
  width: fit-content;
  box-shadow: 0 4px 18px rgba(59,130,246,.35);
}

.hi-clinic-badge {
  position: absolute;
  bottom: 1rem; right: 1rem;
  display: flex;
  align-items: center;
  gap: .35rem;
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.1);
  color: rgba(255,255,255,.75);
  font-size: .67rem; font-weight: 600;
  padding: .28rem .65rem;
  border-radius: .4rem;
  max-width: 200px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
@media (max-width: 480px) { .hi-clinic-badge { display: none; } }

/* Swiper UI overrides */
.hero-swiper .swiper-button-prev,
.hero-swiper .swiper-button-next {
  width: 2.4rem; height: 2.4rem;
  background: rgba(255,255,255,.12);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: 50%;
  transition: background .2s;
}
.hero-swiper .swiper-button-prev:hover,
.hero-swiper .swiper-button-next:hover {
  background: rgba(255,255,255,.22);
}
.hero-swiper .swiper-button-prev::after,
.hero-swiper .swiper-button-next::after {
  font-size: .75rem; font-weight: 900;
  color: #fff;
}
.hero-swiper .swiper-pagination-bullet {
  background: rgba(255,255,255,.45);
  transition: background .2s, transform .2s;
}
.hero-swiper .swiper-pagination-bullet-active {
  background: var(--primary);
  transform: scale(1.3);
}

/* ── SORT DROPDOWN ─ */
/* (sidebar CSS removed — no longer in template) */

/* ── MAIN CONTENT AREA ─────────────────────────────────────────── */

/* Partners compact strip */
.partners-strip {
  display: flex;
  align-items: center;
  gap: .9rem;
  background: #0d1420;
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: .65rem 1rem;
  overflow: hidden;
}
.partners-label {
  display: flex;
  align-items: center;
  gap: .35rem;
  font-size: .67rem; font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .07em;
  white-space: nowrap;
  flex-shrink: 0;
}
.partners-scroll {
  display: flex;
  gap: .55rem;
  overflow-x: auto;
  scrollbar-width: none;
  flex: 1;
}
.partners-scroll::-webkit-scrollbar { display: none; }
.partner-chip {
  display: flex;
  align-items: center;
  gap: .42rem;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 999px;
  padding: .35rem .75rem;
  text-decoration: none;
  color: #cbd5e1;
  flex-shrink: 0;
  transition: border-color .2s, background .2s;
}
.partner-chip:hover {
  border-color: rgba(59,130,246,.4);
  background: rgba(59,130,246,.08);
  color: #e2e8f0;
}
.partner-av {
  width: 26px; height: 26px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(59,130,246,.22), rgba(168,85,247,.18));
  display: flex; align-items: center; justify-content: center;
  font-size: .74rem; font-weight: 800;
  color: var(--primary);
  flex-shrink: 0;
}

/* Results header */
.vitrine-hdr {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #f8fafc;
}
.vitrine-count {
  font-size: 1rem;
  font-weight: 800;
  color: var(--primary);
}

/* ── VM CARD GRID ──────────────────────────────────────────────── */
.vm-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  width: 100%;
  max-width: 1200px;
  margin: 20px auto 0;
}

/* ── DOCTOR CARD ───────────────────────────────────────────────── */
.doctor-card {
  display: flex;
  flex-direction: column;
  background: #1e293b;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #334155;
  text-decoration: none;
  color: #f8fafc;
  transition: transform .22s ease, box-shadow .22s ease;
}
.doctor-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,.45);
}

/* Card image wrapper: fixed height, top-rounded */
.card-img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 16px 16px 0 0;
  display: block;
  position: relative;
}

/* Card body */
.card-content {
  padding: 14px 16px 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  color: #f8fafc;
  flex: 1;
}

/* Category badge — positioned over the image */
.card-category {
  display: inline-block;
  font-size: .6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: #93c5fd;
  background: rgba(59,130,246,.15);
  border: 1px solid rgba(59,130,246,.35);
  border-radius: .35rem;
  padding: .2rem .5rem;
  width: fit-content;
  margin-bottom: 4px;
}

/* Clinic row with circular avatar + name */
.card-clinic-row {
  display: flex;
  align-items: center;
  gap: .45rem;
}
.card-clinic-row::before {
  content: '';
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(59,130,246,.25), rgba(168,85,247,.2));
  flex-shrink: 0;
}
.card-clinic-name {
  font-size: .74rem;
  font-weight: 600;
  color: #94a3b8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}
.card-rating {
  display: inline-flex;
  align-items: center;
  gap: .2rem;
  font-size: .72rem;
  font-weight: 700;
  color: #fbbf24;
  margin-left: auto;
  white-space: nowrap;
  flex-shrink: 0;
}

/* Title */
.card-title {
  font-size: 1.1rem;
  font-weight: 700;
  line-height: 1.3;
  margin: 0;
  color: #f8fafc;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.doctor-card:hover .card-title { color: #93c5fd; }

/* Doctor name */
.card-doctor {
  display: flex;
  align-items: center;
  gap: .28rem;
  font-size: .68rem;
  color: #94a3b8;
}

/* Card footer: price left, CTA button right */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .5rem;
  border-top: 1px solid rgba(255,255,255,.08);
  padding-top: 10px;
  margin-top: auto;
}
.card-price {
  font-size: 1.15rem;
  font-weight: 800;
  color: #10b981;
  letter-spacing: -.02em;
  white-space: nowrap;
}
.card-agendar {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  background: rgba(59,130,246,.15);
  color: #93c5fd;
  padding: .45rem 1rem;
  border-radius: .5rem;
  font-weight: 700;
  font-size: .75rem;
  border: 1.5px solid rgba(59,130,246,.4);
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background .18s, color .18s, border-color .18s;
}
.card-agendar:hover {
  background: rgba(59,130,246,.25);
  color: #bfdbfe;
  border-color: rgba(59,130,246,.6);
}
.doctor-card:hover .card-agendar {
  background: rgba(59,130,246,.2);
  border-color: rgba(59,130,246,.5);
}

/* ── MAP COLUMN (RIGHT, 40%) ───────────────────────────────────── */
.map-column {
  width: 40%;
  height: calc(100vh - 120px);
  position: sticky;
  top: 24px;
  border-radius: 12px;
  overflow: hidden;
  background: #334155;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(255,255,255,.1);
}

/* Empty state */
.vm-empty-state {
  text-align: center;
  padding: 4rem 1rem;
  color: var(--muted);
}

/* ── RESULTS MAP SECTION (shown only after search) ─────────────── */
.results-map-section {
  padding: 0 0 2.5rem;
}

.results-map-panel {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 1rem;
}

.results-map-inner {
  border: 1px solid var(--border);
  border-radius: 1rem;
  overflow: hidden;
  background: var(--card);
}

.results-map-head {
  display: flex;
  align-items: center;
  gap: .45rem;
  padding: .72rem 1rem;
  border-bottom: 1px solid var(--border);
  font-size: .76rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--muted);
}

.results-map-canvas {
  width: 100%;
  height: 420px;
}

/* Leaflet price-pin markers */
.price-pin-wrapper {
  background: transparent;
  border: none;
}

.map-price-pin {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 68px;
  height: 28px;
  padding: 0 .5rem;
  border-radius: 999px;
  text-decoration: none;
  font-size: .72rem;
  font-weight: 800;
  color: #fff;
  background: var(--primary);
  border: 2px solid rgba(255,255,255,.35);
  box-shadow: 0 4px 14px rgba(59,130,246,.45);
  white-space: nowrap;
}

.map-price-pin:hover {
  filter: brightness(1.15);
}

/* Staggered card fade-in */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.doctor-card.fade-in {
  animation: fadeInUp .35s ease both;
}
